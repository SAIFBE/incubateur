APP_NAME="Incubateur CMC"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATE_ON_SERVER
APP_DEBUG=false
APP_URL=https://example.com
ASSET_URL=https://example.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=incubateur
DB_USERNAME=incubateur_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

MYSQL_DATABASE=incubateur
MYSQL_USER=incubateur_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

FILESYSTEM_DISK=public
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.example.com
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=example.com,www.example.com
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="Incubateur CMC"
